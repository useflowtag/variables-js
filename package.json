{
  "name": "@flowtag/variables",
  "version": "0.0.0",
  "description": "Runtime agnostic client for Flowtag variables",
  "main": "index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useflowtag/variables-js.git"
  },
  "homepage": "https://docs.flowtag.dev/sdk/js/variables",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist --clean",
    "lint": "biome check src/*",
    "lint:pub": "publint",
    "fmt": "biome format src/*",
    "lint:ci": "biome ci",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "flowtag",
    "variables",
    "runtime",
    "edge-config",
    "client",
    "fetch",
    "config",
    "remote",
    "remote-config",
    "feature-flags",
    "flags",
    "feature-toggles",
    "toggles",
    "experiments",
    "fetch",
    "browser",
    "node"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Flowtag Team & Contributors <hello@flowtag.dev>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.0.8",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "^25.6.0",
    "publint": "^0.3.19",
    "@semantic-release/npm": "^13.1.5",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
